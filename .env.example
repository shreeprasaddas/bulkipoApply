# Mero Share Automation Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development

# Database (optional for localStorage version)
DATABASE_URL=

# Mero Share Credentials (for testing single account, optional)
DP=18200
USERNAME=your_username
PASSWORD=your_password
CRN_NUMBER=00000000
PIN_1=0000
PIN_2=0000

# Other Configuration
LOG_LEVEL=debug
